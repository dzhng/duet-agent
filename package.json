{
  "name": "duet-agent",
  "version": "0.1.0",
  "description": "An opinionated full-stack agent harness with native memories, interrupts, and multi-agent orchestration",
  "keywords": [
    "agent",
    "ai",
    "llm",
    "memory",
    "multi-agent",
    "orchestrator"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/duetso/duet-agent"
  },
  "bin": {
    "duet-agent": "dist/cli.js"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "setup": "bash scripts/setup-docker.sh",
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "dev": "tsc --watch",
    "eval": "bun test ./evals/*.eval.ts",
    "format": "oxfmt --write --no-error-on-unmatched-pattern",
    "format:check": "oxfmt --check --no-error-on-unmatched-pattern",
    "lint": "oxlint src/",
    "test": "docker run --rm -v \"$PWD:/src:ro\" -w /work -e HOME=/tmp/home -e DUET_TEST_IN_DOCKER=1 oven/bun:1.3.11 sh -lc 'cp -R /src/. /work && bun install --frozen-lockfile && bun test'",
    "example": "tsx examples/basic.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.70.6",
    "@mariozechner/pi-ai": "^0.70.6",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "dedent": "^1.7.2",
    "eventemitter3": "^5.0.0",
    "nanoid": "^5.0.0",
    "typebox": "^1.1.24"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^0.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11"
}
